--- a/qs_manager.sh
+++ b/qs_manager.sh
@@ -18,9 +18,10 @@
     # Send IPC command directly to Main.qml via Quickshell's native IPC handler
     quickshell -p "$SHELL_QML_PATH" ipc call main handleCommand "close" "" "" >/dev/null 2>&1
 
-    CMD="workspace $ACTION"
-    [[ "$TARGET" == "move" ]] && CMD="movetoworkspace $ACTION"
-    hyprctl --batch "dispatch $CMD" >/dev/null 2>&1
+    # KWin: switch desktop via the global shortcut — unlike a raw property
+    # write, this emits currentChanged so the bar and palette follow.
+    qdbus org.kde.kglobalaccel /component/kwin \
+        org.kde.kglobalaccel.Component.invokeShortcut "Switch to Desktop $ACTION" >/dev/null 2>&1
     exit 0
 fi
 
--- a/quickshell/watchers/kb_wait.sh
+++ b/quickshell/watchers/kb_wait.sh
@@ -5,8 +5,9 @@
 mkfifo "$PIPE" 2>/dev/null
 trap 'rm -f "$PIPE"; kill $(jobs -p) 2>/dev/null; exit 0' EXIT INT TERM
 
-if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
-    LC_ALL=C socat -U - UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock 2>/dev/null | grep --line-buffered "activelayout>>" > "$PIPE" &
+if busctl --user status org.kde.keyboard >/dev/null 2>&1; then
+    # KDE: wait for a layoutChanged signal
+    LC_ALL=C dbus-monitor --session "type='signal',interface='org.kde.KeyboardLayouts',member='layoutChanged'" 2>/dev/null | grep --line-buffered -m1 "layoutChanged" > "$PIPE" &
 else
     sleep 10 > "$PIPE" &
 fi
